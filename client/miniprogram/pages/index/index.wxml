<!--index.wxml-->
<navigation-bar title="首页" back="{{false}}" color="black" background="#f6f6f8"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <!-- 头部 -->
  <view class="header">
    <view class="header-left">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="greeting">{{greeting}} {{isGuestMode ? '' : '☀️'}}</view>
    </view>
    <view class="notification-btn" bindtap="onNotification">
      <text class="notification-icon">🔔</text>
    </view>
  </view>

  <!-- 今日复习卡片 -->
  <view class="review-card {{isGuestMode ? 'guest' : ''}}">
    <view class="review-info">
      <text class="review-label">
        {{isGuestMode ? '登录后查看' : (loading.todayDue ? '加载中...' : '来自 ' + deckCount + ' 个卡组')}}
      </text>
      <text class="review-count">{{loading.todayDue ? '--' : todayDueCount}}</text>
      <text class="review-title">今日待复习</text>
    </view>
    
    <button class="start-btn" bindtap="onStartReview" disabled="{{loading.todayDue}}">
      <text class="btn-icon">▶</text>
      {{loading.todayDue ? '加载中...' : '开始复习'}}
    </button>
  </view>

  <!-- 卡组列表 -->
  <view class="decks-section">
    <view class="section-header">
      <text class="section-title">{{isGuestMode ? '示例卡组' : '我的卡组'}}</text>
      <text class="section-more" bindtap="onNavigateToDecks">查看全部</text>
    </view>

    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{loading.decks && decks.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载卡组中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-container" wx:elif="{{!isGuestMode && !loading.decks && decks.length === 0}}">
      <text class="empty-icon">📚</text>
      <text class="empty-title">还没有卡组</text>
      <text class="empty-desc">创建你的第一个卡组，开始学习吧！</text>
      <button class="empty-btn" bindtap="onCreateDeck">创建卡组</button>
    </view>

    <!-- 卡组列表 -->
    <scroll-view class="decks-scroll" scroll-x wx:if="{{decks.length > 0}}">
      <view class="deck-list">
        <view 
          class="deck-card {{isGuestMode ? 'guest' : ''}}" 
          wx:for="{{decks}}" 
          wx:key="id" 
          data-id="{{item.id}}" 
          bindtap="onDeckTap"
        >
          <view class="deck-icon" style="background-color: {{item.bgColor}}; color: {{item.iconColor}}">
            <text wx:if="{{item.icon === 'translate'}}">🌐</text>
            <text wx:elif="{{item.icon === 'history'}}">📜</text>
            <text wx:elif="{{item.icon === 'functions'}}">∑</text>
            <text wx:elif="{{item.icon === 'science'}}">🔬</text>
            <text wx:elif="{{item.icon === 'art'}}">🎨</text>
            <text wx:else>📚</text>
          </view>
          
          <text class="deck-name">{{item.name}}</text>
          <text class="deck-count">{{item.cardCount}}张卡片</text>
          <view class="deck-badge" wx:if="{{!isGuestMode && item.dueCount > 0}}">{{item.dueCount}}张待复</view>
        </view>

        <!-- 新建卡组（仅登录后显示） -->
        <view 
          class="deck-card deck-add" 
          bindtap="onCreateDeck"
          wx:if="{{!isGuestMode}}"
        >
          <view class="add-icon">
            <text>+</text>
          </view>
          <text class="add-text">新建卡组</text>
        </view>
        
        <!-- 游客模式登录提示 -->
        <view 
          class="deck-card deck-login" 
          bindtap="onCreateDeck"
          wx:if="{{isGuestMode}}"
        >
          <view class="login-icon">
            <text>🔐</text>
          </view>
          <text class="login-text">登录后创建</text>
        </view>
      </view>
    </scroll-view>
  </view>
</scroll-view>

<!-- 悬浮拍照按钮 -->
<view class="camera-btn" bindtap="onOpenCamera">
  <text class="camera-icon">📷</text>
</view>

<!-- 登录弹窗 -->
<login-modal id="loginModal" bind:loginSuccess="onLoginSuccess" />
