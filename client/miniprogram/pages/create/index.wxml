<!--create/index.wxml-->
<navigation-bar title="创建卡组" back="{{true}}" color="black" background="#f6f6f8"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <view class="form">
      <!-- 封面图片 -->
      <view class="form-item">
        <text class="label">封面图片</text>
        <view class="cover-upload">
          <view wx:if="{{!coverImage}}" class="upload-placeholder" bindtap="onChooseCoverImage">
            <text class="upload-icon">📷</text>
            <text class="upload-text">{{uploading ? '上传中...' : '点击拍照或选择图片'}}</text>
          </view>
          <view wx:else class="cover-preview">
            <image class="cover-image" src="{{coverImage}}" mode="aspectFill"></image>
            <view class="cover-actions">
              <button class="action-btn change-btn" bindtap="onChooseCoverImage">更换图片</button>
              <button class="action-btn delete-btn" bindtap="onRemoveCoverImage">删除</button>
            </view>
          </view>
        </view>
      </view>

      <!-- 卡组名称 -->
      <view class="form-item">
        <text class="label">卡组名称 <text class="required">*</text></text>
        <input 
          class="input" 
          placeholder="请输入卡组名称，如：英语单词" 
          value="{{name}}" 
          bindinput="onNameInput" 
          maxlength="50"
        />
      </view>
      
      <!-- 卡组描述 -->
      <view class="form-item">
        <text class="label">卡组描述</text>
        <textarea 
          class="textarea" 
          placeholder="请输入卡组描述（选填），如：四六级核心词汇" 
          value="{{description}}" 
          bindinput="onDescInput"
          maxlength="200"
        />
      </view>
      
      <!-- 图标选择 -->
      <view class="form-item">
        <text class="label">图标</text>
        <view class="icon-grid">
          <view 
            class="icon-item {{icon === item.value ? 'active' : ''}}"
            wx:for="{{icons}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="onIconSelect"
          >
            <text class="icon-emoji">{{item.emoji}}</text>
            <text class="icon-name">{{item.name}}</text>
          </view>
        </view>
      </view>
      
      <!-- 提交按钮 -->
      <button 
        class="submit-btn {{submitting ? 'submitting' : ''}}" 
        bindtap="onSubmit"
        disabled="{{submitting || !name}}"
      >
        {{submitting ? '创建中...' : '创建卡组'}}
      </button>
    </view>
  </view>
</scroll-view>
